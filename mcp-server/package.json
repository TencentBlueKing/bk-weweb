{
  "name": "@blueking/bk-weweb-mcp",
  "version": "1.0.1",
  "description": "MCP Server for BK-WeWeb micro-frontend framework",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "bk-weweb-mcp": "./dist/index.js",
    "bk-weweb-mcp-sse": "./dist/index.js",
    "bk-weweb-mcp-stdio": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "tsx watch src/stdio.ts",
    "start": "node dist/index.js",
    "start:stdio": "node dist/stdio.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bk-weweb-mcp",
    "bk-weweb",
    "@blueking/bk-weweb-mcp",
    "blueking"
  ],
  "author": "BlueKing",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.3.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}